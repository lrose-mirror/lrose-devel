/**********************************************************************
 * TDRP params for DsrWebPost
 **********************************************************************/

//======================================================================
//
// DsrWebPost reads radar beam-by-beam data from a DSR-format FMQ and 
//   posts the data to the specified URL.
//
//======================================================================
 
///////////// debug ///////////////////////////////////
//
// Debug option.
// If set, debug messages will be printed with the appropriate level of 
//   detail.
//
// Type: enum
// Options:
//     DEBUG_OFF
//     DEBUG_NORM
//     DEBUG_VERBOSE
//

debug = DEBUG_OFF;

///////////// instance ////////////////////////////////
//
// Process instance.
// Used for registration with procmap.
// Type: string
//

instance = "test";

//======================================================================
//
// DATA INPUT.
//
//======================================================================
 
///////////// input_fmq_url ///////////////////////////
//
// Input URL for DsRadar data via FMQ.
// Type: string
//

input_fmq_url = "fmqp:://localhost::fmq/dsRadar";

//======================================================================
//
// RADAR PROCESSING OPTIONS.
//
//======================================================================
 
///////////// override_radar_location /////////////////
//
// Option to override Dsr radar location.
// If TRUE, the UF output will use location information specified in 
//   'radar_location'.
// Type: boolean
//

override_radar_location = FALSE;

///////////// radar_location //////////////////////////
//
// .
// The radar_location need only be set if 'override_radar_location' is 
//   TRUE.
//
// Type: struct
//   typedef struct {
//      string name;
//      double latitude;
//      double longitude;
//      double altitude;
//   }
//
//

radar_location = { "not_set", 0, 0, 0 };

///////////// end_of_vol_decision /////////////////////
//
// Decision type for end-of-volume.
// If END_OF_VOL_FLAG, the end-of-volume flag in the data will be used 
//   to trigger the end of volume. If LAST_TILT_IN_VOL, the end of the 
//   tilt number given by 'last_tilt_in_vol' will be used  to trigger the 
//   end-of-volume.
//
// Type: enum
// Options:
//     END_OF_VOL_FLAG
//     LAST_TILT_IN_VOL
//

end_of_vol_decision = END_OF_VOL_FLAG;

///////////// last_tilt_in_vol ////////////////////////
//
// The tilt number used to end the volume.
// Only applies if 'end_of_vol_decision' is set to LAST_TILT_IN_VOL.
// Type: long
//

last_tilt_in_vol = 0;

///////////// remove_antenna_transitions //////////////
//
// Option to remove out beams in which the antenna is in transition.
// When the antenna is changing from one volume scan to the next, the 
//   antenna is sometimes in a transtion state. If this is set, the 
//   transition beams are not included in the output files.
// Type: boolean
//

remove_antenna_transitions = TRUE;

//======================================================================
//
// DATA OUTPUT.
//
//======================================================================
 
///////////// output_raw_data /////////////////////////
//
// Option to output data files on disk.
// If TRUE, raw data files will be output at the location specified in 
//   'output_raw_dir'.
// Type: boolean
//

output_raw_data = FALSE;

///////////// output_raw_dir //////////////////////////
//
// Dir of raw data output files.
// This only needs to be set if 'output_raw_data' is TRUE. The directory 
//   must exist.
// Type: string
//

output_raw_dir = "./output";

///////////// output_raw_prefix ///////////////////////
//
// Prefix to the file name.
// This only needs to be set if 'output_raw_data' is TRUE.
// Type: string
//

output_raw_prefix = "Radar_";

///////////// output_raw_ext //////////////////////////
//
// Extension to the file name.
// This only needs to be set if 'output_raw_data' is TRUE.
// Type: string
//

output_raw_ext = "raw";

///////////// radial_collection_size //////////////////
//
// The number of radials to collect in a data data file.
// Should be set to 120 for bandwidth purposes.
// Type: long
//

radial_collection_size = 120;

///////////// override_vcp ////////////////////////////
//
// Option to override the VCP number.
// If TRUE, the application will use the specified VCP number.
// Type: boolean
//

override_vcp = FALSE;

///////////// vcp /////////////////////////////////////
//
// Use this VCP for the collected data.
// Only used if 'override_vcp' is TRUE.
// Type: long
//

vcp = 21;

///////////// tilt_increment //////////////////////////
//
// Option to increment the tilt number. This is sometimes needed for
// NEXRAD data sources to avoid 0-based tilt numbers.
// If TRUE, the application will increment the tilt number by 1.
// Type: boolean
//

tilt_increment = FALSE;

///////////// post_data_web ///////////////////////////
//
// Option to post data to a web server in JSON format.
// If TRUE, data will be posted to the URL specified in 'post_data_url'.
// Type: boolean
//

post_data_web = FALSE;

///////////// post_data_url ///////////////////////////
//
// URL to post data in JSON format.
// This only needs to be set if 'post_data_web' is TRUE.
// Type: string
//

post_data_url = "http://localhost/PostRadarDataJSON";

